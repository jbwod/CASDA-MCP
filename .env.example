# Public CASDA metadata endpoints (defaults shown)
CASDA_BASE_URL=https://casda.csiro.au
CASDA_TAP_URL=https://casda.csiro.au/casda_vo_tools/tap/sync
CASDA_TAP_ASYNC_URL=https://casda.csiro.au/casda_vo_tools/tap/async
CASDA_DATALINK_URL=https://data.csiro.au/casda_vo_proxy/vo/datalink/links
CASDA_SODA_URL=https://casda.csiro.au/casda_data_access/data/async
CASDA_LOGIN_URL=https://data.csiro.au/casda_vo_proxy/vo/tap/availability
CASDA_SIA1_URL=https://casda.csiro.au/casda_vo_tools/sia1/query
CASDA_SIA1_SURVEYS_URL=https://casda.csiro.au/casda_vo_tools/sia1/surveys
CASDA_SIA2_URL=https://casda.csiro.au/casda_vo_tools/sia2/query
CASDA_SCS_BASE_URL=https://casda.csiro.au/casda_vo_tools/scs
CASDA_SSA_URL=https://casda.csiro.au/casda_vo_tools/ssa/query
CASDA_EVENTS_URL=https://casda.csiro.au/casda_data_access/observations/events

# OPAL credentials. Leave unset for read-only metadata access.
CASDA_USERNAME=
CASDA_PASSWORD=

# State-changing / advanced operations are off by default.
CASDA_ENABLE_STAGING=false
CASDA_ENABLE_DOWNLOADS=false
CASDA_ENABLE_ADVANCED_ADQL=false
# Must be an absolute, dedicated directory; filesystem roots are rejected.
CASDA_DOWNLOAD_DIR=
CASDA_ALLOW_OVERWRITE=false

# Safety and performance limits
CASDA_MAX_RESULTS=100
CASDA_MAX_CONE_RADIUS_DEG=5
CASDA_MAX_STAGE_PRODUCTS=20
CASDA_MAX_STAGE_BYTES=107374182400
CASDA_ALLOW_UNKNOWN_STAGE_SIZE=false
CASDA_MAX_MANIFEST_PRODUCTS=100
CASDA_MAX_DOWNLOAD_BYTES=53687091200
CASDA_MAX_RESPONSE_BYTES=16777216
CASDA_REQUEST_TIMEOUT_SECONDS=30
CASDA_DOWNLOAD_TIMEOUT_SECONDS=300
CASDA_MAX_RETRIES=3
CASDA_CACHE_TTL_SECONDS=60
CASDA_CACHE_MAX_ENTRIES=256

# Optional SQLite persistence. The default is process-local memory only.
CASDA_STATE_DB=
